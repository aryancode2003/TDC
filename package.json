{
  "name": "tdc-platform",
  "version": "1.0.0",
  "description": "The DABBA Company - India's Smart Subscription Platform for Home-Cooked Tiffin Services",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/admin-dashboard",
    "apps/partner-dashboard",
    "packages/*"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "setup": "npm install && npm run build",
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"apps/**/*.{ts,tsx,json,md}\" \"packages/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,json,md}\" \"packages/**/*.{ts,tsx,json,md}\"",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "prettier": "^3.0.0",
    "typescript": "^5.2.0"
  },
  "author": "The DABBA Company",
  "license": "PROPRIETARY"
}
